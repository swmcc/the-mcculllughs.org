<%
  # Split photos into rows for animation
  photos = @photo_data
  row_size = [(photos.size / 8.0).ceil, 1].max
  rows = photos.any? ? photos.each_slice(row_size).to_a : []
%>

<div class="h-screen bg-neutral-900 overflow-hidden relative">
  <!-- Photo rows as full-screen background -->
  <div class="absolute inset-0 flex flex-col justify-center gap-0.5">
    <% rows.each_with_index do |row_photos, index| %>
      <% direction = index.even? ? 'left' : 'right' %>
      <div class="photo-row photo-row-<%= direction %> flex gap-0.5">
        <% 3.times do %>
          <% row_photos.each do |photo| %>
            <%= link_to public_photo_path(photo[:short_code]), class: "flex-shrink-0 block overflow-hidden rounded hover:scale-105 transition-transform duration-300" do %>
              <%= image_tag photo[:thumb_url],
                  class: "w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 object-cover",
                  loading: "lazy",
                  decoding: "async" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Overlay to darken photos behind hero -->
  <div class="absolute inset-0 bg-neutral-900/40 pointer-events-none"></div>

  <!-- Hero section floating on top -->
  <div class="absolute inset-0 flex items-center justify-center z-10">
    <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl px-8 sm:px-12 py-8 sm:py-10 text-center mx-4">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-neutral-800 mb-2">the-mcculloughs.org</h1>
      <p class="text-neutral-500 text-sm sm:text-base mb-6">1919 – <%= Date.current.year %></p>
      <%= link_to "Sign In", new_user_session_path,
          class: "inline-block px-8 py-3 bg-neutral-900 hover:bg-neutral-800 text-white text-sm font-medium rounded-xl transition-colors shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all" %>
    </div>
  </div>

  <!-- Footer -->
  <div class="absolute bottom-0 left-0 right-0 z-10">
    <%= render "shared/footer" %>
  </div>
</div>

<style>
  .photo-row {
    width: max-content;
  }

  .photo-row-left {
    animation: scroll-left 90s linear infinite;
  }

  .photo-row-right {
    animation: scroll-right 90s linear infinite;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  @keyframes scroll-right {
    0% { transform: translateX(-33.333%); }
    100% { transform: translateX(0); }
  }

  .photo-row:hover {
    animation-play-state: paused;
  }
</style>
