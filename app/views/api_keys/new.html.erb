<% content_for :title, "Create API Key" %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <div class="p-2 bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-neutral-800">Create API Key</h1>
        <p class="text-sm text-neutral-500">Generate a new access token</p>
      </div>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-6">
    <%= form_with model: @api_key, class: "space-y-6" do |f| %>
      <% if @api_key.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <div class="flex items-center gap-2 text-red-800 font-medium mb-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Please fix the following errors:
          </div>
          <ul class="list-disc list-inside text-sm text-red-700">
            <% @api_key.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-neutral-700 mb-2" %>
        <%= f.text_field :name,
            placeholder: "e.g., Indexatron, My Script",
            class: "w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-colors",
            autofocus: true %>
        <p class="mt-2 text-sm text-neutral-500">A friendly name to help you remember what this key is used for.</p>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <%= f.submit "Create API Key", class: "flex-1 px-4 py-3 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-medium rounded-lg hover:from-amber-600 hover:to-orange-700 transition-all cursor-pointer" %>
        <%= link_to "Cancel", api_keys_path, class: "px-4 py-3 text-neutral-600 hover:text-neutral-800 font-medium transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- Warning -->
  <div class="mt-6 bg-amber-50 border border-amber-200 rounded-xl p-4">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      <div class="text-sm text-amber-700">
        <p class="font-medium text-amber-800">Important</p>
        <p>You'll only see the full API key once after creation. Make sure to copy it somewhere safe!</p>
      </div>
    </div>
  </div>
</div>
