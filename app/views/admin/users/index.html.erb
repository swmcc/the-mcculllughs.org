<% content_for :title, "Users | Admin" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <div class="p-2 bg-gradient-to-br from-violet-500 to-purple-600 rounded-xl">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-neutral-800">Users</h1>
        <p class="text-sm text-neutral-500">Manage all registered users</p>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-neutral-800"><%= @stats[:total] %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Total Users</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-violet-600"><%= @stats[:admins] %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Admins</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-neutral-800"><%= @stats[:members] %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Members</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-blue-600"><%= number_with_delimiter(@stats[:total_uploads]) %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Total Uploads</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-green-600"><%= number_with_delimiter(@stats[:public_uploads]) %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Public Photos</div>
    </div>
    <div class="bg-white rounded-xl border border-neutral-200 p-4">
      <div class="text-2xl font-bold text-amber-600"><%= @stats[:total_galleries] %></div>
      <div class="text-xs text-neutral-500 uppercase tracking-wide">Galleries</div>
    </div>
  </div>

  <!-- Users Table -->
  <div class="bg-white rounded-xl border border-neutral-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-neutral-50 border-b border-neutral-200">
            <th class="text-left text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">User</th>
            <th class="text-left text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Role</th>
            <th class="text-center text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Galleries</th>
            <th class="text-center text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Uploads</th>
            <th class="text-center text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Slideshows</th>
            <th class="text-left text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Joined</th>
            <th class="text-right text-xs font-medium text-neutral-500 uppercase tracking-wider px-6 py-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          <% @users.each do |user| %>
            <tr class="hover:bg-neutral-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-medium text-sm
                    <%= user.admin? ? 'bg-gradient-to-br from-violet-500 to-purple-600' : 'bg-gradient-to-br from-blue-500 to-cyan-500' %>">
                    <%= user.name.first.upcase %>
                  </div>
                  <div>
                    <div class="font-medium text-neutral-800"><%= user.name %></div>
                    <div class="text-sm text-neutral-500"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <% if user.admin? %>
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-violet-100 text-violet-700">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    Admin
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-neutral-100 text-neutral-600">
                    Member
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="text-sm font-medium text-neutral-700"><%= user.galleries.size %></span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="text-sm font-medium text-neutral-700"><%= number_with_delimiter(user.uploads.size) %></span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="text-sm font-medium text-neutral-700"><%= user.slideshows.size %></span>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm text-neutral-600"><%= user.created_at.strftime("%-d %b %Y") %></div>
                <div class="text-xs text-neutral-400"><%= time_ago_in_words(user.created_at) %> ago</div>
              </td>
              <td class="px-6 py-4 text-right">
                <% if user != current_user %>
                  <%= button_to admin_user_path(user),
                      method: :delete,
                      data: { turbo_confirm: "Delete #{user.name}? This will remove all their galleries, uploads, and slideshows. This cannot be undone." },
                      class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 hover:text-white hover:bg-red-600 border border-red-200 hover:border-red-600 rounded-lg transition-colors" do %>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete
                  <% end %>
                <% else %>
                  <span class="text-xs text-neutral-400">You</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
